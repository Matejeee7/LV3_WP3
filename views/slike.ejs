<!DOCTYPE html>
<html lang="hr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Galerija filmskih postera s lightbox prikazom bez JavaScripta.">
    <title>Filmovi Web | Galerija</title>
    <link rel="stylesheet" href="/css/style_slike.css">
</head>
<body>
    <header class="site-header">
        <div class="header-inner">
            <h1>Filmovi Web</h1>
            <p>Galerija filmskih postera</p>
        </div>
    </header>

    <div class="nav-wrapper">
        <button class="menu-toggle" aria-label="Prikaži navigaciju">☰ Menu</button>
        <nav class="main-nav" aria-label="Glavna navigacija">
            <ul>
                <li><a href="/">Početna</a></li>
                <li><a href="/grafikon">Grafikon</a></li>
                <li><a href="/slike">Galerija</a></li>
            </ul>
        </nav>
    </div>

    <main class="gallery-page">
        <section class="gallery-section" aria-labelledby="galerija-naslov">
            <h2 id="galerija-naslov">Galerija filmskih postera</h2>
            <p class="gallery-description">Klikom na sliku prikazuje se povećani prikaz, a sve slike koriste lazy-loading za brže učitavanje.</p>

            <div class="gallery-grid">
                <% slike.forEach((slika, index) => { %>
                    <figure class="gallery-item">
                        <a href="#img<%= index + 1 %>">
                            <img src="/images/<%= slika.file %>" alt="<%= slika.alt %>" loading="lazy">
                        </a>
                        <figcaption><%= slika.title %></figcaption>
                    </figure>
                <% }) %>
            </div>
        </section>

        <% slike.forEach((slika, index) => { %>
            <div id="img<%= index + 1 %>" class="lightbox">
                <a href="#" class="close" aria-label="Zatvori prikaz">×</a>
                <img src="/images/<%= slika.file %>" alt="Povećani poster filma <%= slika.title %>">
            </div>
        <% }) %>
    </main>

    <footer class="site-footer">
        <p>&copy; 2026 Filmovi Web | Web programiranje</p>
    </footer>
</body>
</html>